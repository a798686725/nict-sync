{
  "name": "nict-calculator",
  "version": "1.6",
  "description": "NICT 吊数计算器 - 局域网同步版",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "build": {
    "appId": "com.nict.calculator",
    "productName": "NICT吊数计算器",
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "portable": {
      "artifactName": "NICT吊数计算器_同步版.exe"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html"
    ],
    "extraResources": []
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.0.0",
    "@tauri-apps/cli": "^1.5.0"
  }
}
