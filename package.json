{
  "name": "nict-calculator",
  "version": "2.0.0",
  "description": "NICT 吊数计算器 V2.0 - 局域网同步版",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win portable",
    "build-dir": "electron-builder --win --dir"
  },
  "build": {
    "appId": "com.nict.calculator",
    "productName": "NICT吊数计算器",
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "portable": {
      "artifactName": "NICT吊数计算器_v${version}_便携版.exe"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "src/**"
    ]
  },
  "dependencies": {
    "electron-log": "^5.1.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}